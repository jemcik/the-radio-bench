{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/hooks/i18n-edit-check.sh",
            "timeout": 30,
            "statusMessage": "Linting i18n…"
          }
        ]
      }
    ]
  }
}
