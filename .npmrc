# Several @visx/* packages still advertise peerDependencies capped at
# React 18 (e.g. @visx/axis@3.12.0 → react@^16|^17|^18). They work fine
# with React 19 at runtime; only the peer-dep constraint is out of date.
# `npm ci` is strict about peer deps by default and fails CI install.
# Enable legacy peer-dep resolution so npm uses its pre-v7 algorithm
# (same behaviour as `npm install` locally) and the lockfile resolves
# cleanly.
legacy-peer-deps=true
